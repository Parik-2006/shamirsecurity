# Backend Environment Variables
# Copy this to .env and fill in your values

# Your deployed frontend URL (no trailing slash)
FRONTEND_URL=https://your-frontend.onrender.com

# Your deployed backend URL (no trailing slash)  
BACKEND_URL=https://your-backend.onrender.com

# Supabase credentials
SUPABASE_URL=https://tacsrdvzgcsucparujcr.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Flask secret key (generate a random one)
FLASK_SECRET_KEY=generate-a-random-secret-key-here

# Set to false in production
FLASK_DEBUG=false

# Port (Render sets this automatically)
PORT=5000
